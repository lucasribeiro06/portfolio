    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an expert executive copyeditor. Your sole task is to polish, refine, and maximize the hook retention of the raw LinkedIn draft provided below.\n\nRaw Draft to Edit:\n{{ $json.text }}\n\nCRITICAL EDITING RULES:\n1. THE HOOK: Sharpen the very first line. Ensure it is intensely compelling, concise, and forces the reader to click \"...see more\".\n2. GRAPHIC LAYOUT: Ensure formatting is hyper-breathable. Break up walls of text.\n3. FLOW: Remove any robotic AI phrasing, cliches, or corporate filler words.\n4. OUTPUT: Output ONLY the final polished LinkedIn post. Do not include any intros or bracketed tags.",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1664,
        -192
      ],
