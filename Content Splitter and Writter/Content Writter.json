    {
      "parameters": {
        "jsCode": "const inputs = $input.all();\n\nconst linkedinFinal = inputs[0]?.json?.text || \"\";\nconst twitterFinal = inputs[1]?.json?.text || \"\";\nconst newsletterFinal = inputs[2]?.json?.text || \"\";\n\nconst originalLink = $('Google Sheets Trigger').first().json['Source URL'] || \"\";\nconst fullText = $('/scrape').first().json.markdown || \"\";\n\nconst titleMatch = fullText.match(/^#\\s+(.*)/m);\nconst articleTitle = titleMatch ? titleMatch[1].trim() : \"Growth Article\";\n\nreturn [\n  {\n    json: {\n      metadata: {\n        title: articleTitle,\n        source_url: originalLink,\n        full_text: fullText,\n        status: \"polished_by_editor\"\n      },\n      final_channels: {\n        linkedin: linkedinFinal,\n        twitter: twitterFinal,\n        newsletter: newsletterFinal\n      }\n    }\n  }\n];"
      },
