      "name": "Linkedin Editor"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an elite platform-native editor specializing in viral growth mechanics on Twitter/X. Your sole task is to audit and rewrite the raw Twitter thread provided below to ensure maximum retention.\n\nRaw Draft to Edit:\n{{ $json.text }}\n\nCRITICAL EDITING RULES:\n1. THREAD HOOK: Ensure the first tweet contains an unmissable open loop.\n2. TWEET PACING: Verify that every single tweet ends elegantly and naturally compels the reader to scroll down.\n3. CONCISENESS: Aggressively trim fluff. Ensure fractional counters (e.g., 1/, 2/) remain perfectly intact.\n4. OUTPUT: Output ONLY the final polished Twitter thread. Do not include any meta-commentary.",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1664,
        176
      ],
      "id": "ee7c95a2-341d-4d71-a171-79e551764c33",
      "name": "Twitter Editor"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a premium business newsletter copyeditor at Lead.ing PRO. Your task is to refine and polish the raw email draft provided below to ensure maximum value-delivery and executive readability.\n\nRaw Draft to Edit:\n{{ $json.text }}\n\nCRITICAL EDITING RULES:\n1. HEADLINES: Ensure the subject lines are punchy and optimized for open rates. Verify markdown headers (##) are clean.\n2. TONE AUDIT: Enforce a methodical, system-driven, and highly consultative tone.\n3. RETENTION FLOW: Smooth out transitions between paragraphs.\n4. OUTPUT: Output ONLY the final production-ready newsletter text.",
        "batching": {}
      },
