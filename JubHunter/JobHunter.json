    {
      "parameters": {
        "jsCode": "const input = items[0].json;\nconst html = input.data || input.body || input.html || \"\";\n\nif (!html || html.length < 100) {\n  return [{ json: { error: \"HTML not received or blocked.\" } }];\n}\n\nconst cleanHTML = (text) => {\n  if (!text) return \"\";\n  return text\n    .replace(/<br\\s*\\/?>/gi, ' ')\n    .replace(/<li>/gi, ' ')\n    .replace(/<[^>]*>?/gm, '')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .trim();\n};\n\nconst sanitize = (text) => {\n  return text\n    .replace(/[\\n\\r\\t]/gm, ' ')\n    .replace(/\\s\\s+/g, ' ')\n    .trim();\n};\n\nlet jobData = {\n  Title: \"Not found\",\n  \"Job Link\": \"Not found\",\n  Requirements: \"Not found\",\n  Benefits: \"Not found\",\n  Description: \"Not found\",\n};\n\ntry {\n  const urlMatch = html.match(/<link rel=\"canonical\" href=\"([^\"]+)\"/);\n  if (urlMatch) jobData[\"Job Link\"] = urlMatch[1];\n\n  const titleMatch = html.match(/top-card-layout__title[^>]*>([\\s\\S]*?)<\\/h1>/);\n  if (titleMatch) jobData.Title = sanitize(cleanHTML(titleMatch[1]));\n\n  const descMatch = html.match(/show-more-less-html__markup[^>]*>([\\s\\S]*?)<\\/div>/);\n  if (descMatch) {\n    const rawDesc = descMatch[1];\n    jobData.Description = sanitize(cleanHTML(rawDesc));\n\n    const reqKeywords = /Requisitos:|Perfil que buscamos:|Qualificações:|O que você precisa ter:|Desejável:|Requirements:|Qualifications:|What you need:/i;\n    const reqParts = rawDesc.split(reqKeywords);\n    if (reqParts.length > 1) {\n      jobData.Requirements = sanitize(cleanHTML(reqParts[1].split('</ul>')[0]));\n    }\n\n    const benKeywords = /Benefícios:|Pacote de Benefícios:|Vantagens:|O que oferecemos:|Benefits:|Perks:|What we offer:/i;\n    const benParts = rawDesc.split(benKeywords);\n    if (benParts.length > 1) {\n      jobData.Benefits = sanitize(cleanHTML(benParts[1].split('</ul>')[0]));\n    }\n  }\n} catch (e) {\n  jobData.error = e.message;\n}\n\nreturn [{ json: jobData }];"
      },
